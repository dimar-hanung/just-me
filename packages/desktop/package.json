{
  "name": "@just-me/desktop",
  "version": "0.3.0",
  "private": true,
  "description": "Just Me personal todo desktop app",
  "author": "Dimar Hanung <dimarhanung@ecampus.ut.ac.id>",
  "homepage": "https://github.com/dimar-hanung/just-me",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "build": "pnpm run prepare:app && electron-builder --linux deb AppImage",
    "build:linux": "pnpm run prepare:app && electron-builder --linux deb AppImage",
    "build:win": "pnpm run prepare:app && electron-builder --win nsis",
    "build:all": "pnpm run prepare:app && electron-builder --linux deb AppImage --win nsis",
    "prepare:app": "pnpm --filter @just-me/core build && pnpm --filter @just-me/api build && pnpm --filter @just-me/web build && node scripts/copy-web-dist.mjs && tsc",
    "dev": "tsc && electron .",
    "start": "electron ."
  },
  "dependencies": {
    "@just-me/api": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "dev.justme.todos",
    "productName": "Just Me",
    "directories": {
      "output": "../../release"
    },
    "files": [
      "dist/**/*",
      "web-dist/**/*",
      "package.json",
      "node_modules/**/*",
      "../api/dist/**/*",
      "../core/dist/**/*"
    ],
    "extraResources": [],
    "linux": {
      "target": ["deb", "AppImage"],
      "category": "Office",
      "executableName": "just-me",
      "artifactName": "JustMe-${version}-${arch}.${ext}",
      "maintainer": "Dimar Hanung <dimarhanung@ecampus.ut.ac.id>"
    },
    "win": {
      "target": ["nsis"],
      "artifactName": "JustMe-${version}-${arch}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Just Me",
      "uninstallDisplayName": "Just Me"
    }
  }
}
