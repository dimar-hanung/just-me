{
  "name": "just-me",
  "private": true,
  "scripts": {
    "dev": "JUST_ME_DEV_API_PORT=7842 pnpm --parallel --filter @just-me/api --filter @just-me/web dev",
    "dev:api": "JUST_ME_DEV_API_PORT=7842 pnpm --filter @just-me/api dev",
    "dev:web": "pnpm dev",
    "dev:desktop": "pnpm --filter @just-me/desktop dev",
    "dev:mcp": "pnpm --filter @just-me/mcp dev",
    "build": "pnpm --filter @just-me/core build && pnpm --filter @just-me/api build && pnpm --filter @just-me/web build && pnpm --filter @just-me/mcp build",
    "build:desktop": "pnpm --filter @just-me/desktop build",
    "build:desktop:linux": "pnpm --filter @just-me/desktop build:linux",
    "build:desktop:win": "pnpm --filter @just-me/desktop build:win",
    "build:desktop:all": "pnpm --filter @just-me/desktop build:all"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "supportedArchitectures": {
      "os": ["current", "win32"],
      "cpu": ["x64"],
      "libc": ["current"]
    }
  }
}
